Func StartTrialDlg%();
Var Dummy%, ok%;
Var Grp1Col1% := 5, Grp1Col2% := 27, Grp2Col1% := 42, Grp2Col2% := 64;

FilePathSet("", 3, "Folder to save data to.", 1);
SavePath$ := FilePath$(3);

Dlgcreate("Trial order");
DlgAllow(1023, 0, ChangeStProf%);
DlgText("Would you like to use the current stimulation profile or", 15, 1, 51);
DlgText("move on to the next stimulation profile?", 20, 2, 49);
GrpSel% :=  DlgGroup("Selected profile:", 1, 4, 35, 9);
GrpNext% := DlgGroup("Next:", 38, 4, 35, 9);

DlgText("Profile:", Grp1Col1%, 5, 10);
DlgText("Pulse Frequency (Hz):", Grp1Col1%, 6, 10);
DlgText("Waveform:", Grp1Col1%, 7, 10);
DlgText("Electrode Type:", Grp1Col1%, 8, 10);
DlgText("Intensity increment (mA):", Grp1Col1%, 9, 10);
DlgText("Train Frequency (Hz):", Grp1Col1%, 10, 10);
DlgText("Max duration (s):", Grp1Col1%, 11, 10);
DlgText("Mode:", Grp1Col1%, 12, 10);

CurDlgEnt%[0] := DlgText("________", Grp1Col2%, 5);
CurDlgEnt%[1] := DlgText("________", Grp1Col2%, 6);
CurDlgEnt%[2] := DlgText("________", Grp1Col2%, 7);
CurDlgEnt%[3] := DlgText("________", Grp1Col2%, 8);
CurDlgEnt%[4] := DlgText("______", Grp1Col2%, 9);
CurDlgEnt%[5] := DlgText("________", Grp1Col2%, 10);
CurDlgEnt%[6] := DlgText("________", Grp1Col2%, 11);
CurDlgEnt%[7] := DlgText("__________________", Grp1Col2%-12, 12);

DlgText("Profile:", Grp2Col1%, 5, 10);
DlgText("Pulse Frequency (Hz):", Grp2Col1%, 6, 10);
DlgText("Waveform:", Grp2Col1%, 7, 10);
DlgText("Electrode Type:", Grp2Col1%, 8, 10);
DlgText("Intensity increment (mA):", Grp2Col1%, 9, 10);
DlgText("Train Frequency (Hz):", Grp2Col1%, 10, 10);
DlgText("Max duration (s):", Grp2Col1%, 11, 10);
DlgText("Mode:", Grp2Col1%, 12, 10);

NextDlgEnt%[0] := DlgText("________", Grp2Col2%, 5);
NextDlgEnt%[1] := DlgText("________", Grp2Col2%, 6);
NextDlgEnt%[2] := DlgText("________", Grp2Col2%, 7);
NextDlgEnt%[3] := DlgText("________", Grp2Col2%, 8);
NextDlgEnt%[4] := DlgText("______", Grp2Col2%, 9);
NextDlgEnt%[5] := DlgText("________", Grp2Col2%, 10);
NextDlgEnt%[6] := DlgText("________", Grp2Col2%, 11);
NextDlgEnt%[7] := DlgText("__________________", Grp2Col2%-12, 12);

DlgButton(1, "Start", 0, 14, 14);
DlgButton(2, "Next", NextP%, 51, 14);
DlgButton(0, "Cancel", -1, 33, 15);

Ok% := DlgShow(Dummy%);

If GlobalIdx% = -1 then GlobalIdx% := 0 endif;

Return Ok%
end

Func ChangeStProf%(Item%);

Var Got% := GetSettings%(OutOrder%[GlobalIdx%]);  'Get CURRENT profile settings
    DlgValue$(CurDlgEnt%[0], Print$("%d", OutOrder%[GlobalIdx%]));
    DlgValue$(CurDlgEnt%[1], Print$("%.2f", Fr[1]));
    DlgValue$(CurDlgEnt%[2], Print$("%s", WaveType$[WType%[1]+1]));
    DlgValue$(CurDlgEnt%[3], Print$("%s", ElecType$[EType%[1]]));

    If ModeType%[0] = 1 or ModeType%[0] = 2 then
        DlgValue$(CurDlgEnt%[4], Print$("%.2f", IntInc[1]));
        DlgValue$(CurDlgEnt%[5], Print$("%.2f", TrFr[1]));
    else
        DlgValue$(CurDlgEnt%[4], Print$("______"));
        DlgValue$(CurDlgEnt%[5], Print$("________"));
    endif    
        DlgValue$(CurDlgEnt%[6], Print$("%d", MDur[1]));
        DlgValue$(CurDlgEnt%[7], Print$("%s", ModeType$[ModeType%[0]]));
    
    If NumStimProf% > 1 then
    
    If GlobalIdx% = NumStimProf% -1 then
        GlobalIdx% := -1;
     endif
Got% := GetSettings%(OutOrder%[GlobalIdx%+1]); 'Get NEXT profile settings        

    DlgValue$(NextDlgEnt%[0], Print$("%d", OutOrder%[GlobalIdx%+1]));
    DlgValue$(NextDlgEnt%[1], Print$("%.2f", Fr[1]));
    DlgValue$(NextDlgEnt%[2], Print$("%s", WaveType$[WType%[1]+1]));
    DlgValue$(NextDlgEnt%[3], Print$("%s", ElecType$[EType%[1]]));
    If ModeType%[0] = 1 or ModeType%[0] = 2 then
        DlgValue$(NextDlgEnt%[4], Print$("%.2f", IntInc[1]));
        DlgValue$(NextDlgEnt%[5], Print$("%.2f", TrFr[1]));
    Else
        DlgValue$(NextDlgEnt%[4], Print$("______"));
        DlgValue$(NextDlgEnt%[5], Print$("________"));
    endif     
    DlgValue$(NextDlgEnt%[6], Print$("%d", MDur[1]));
    DlgValue$(NextDlgEnt%[7], Print$("%s", ModeType$[ModeType%[0]]));
    DlgEnable(1, GrpNext%);
    DlgEnable(1, -2);
    'If GlobalIdx% = -1 then GlobalIdx% := 0 endif;
else
    DlgEnable(0, GrpNext%);
    DlgEnable(0, -2);
endif    

Return 1
end

Func NextP%();
'Var i%;
'For i% := 0 to Len(CurDlgEnt%[]) -1 do
'DlgValue$(CurDlgEnt%[i%], DlgValue$(NextDlgEnt%[i%]));
'Next
If GlobalIdx% +1 > NumStimProf% -1 then
    GlobalIdx% := 0 
else    
    GlobalIdx% += 1;
endif    
ChangeStProf%(0);
return 1
end

Func DetectSerialPorts%();
Var i%, err%, List0%, Ok%;
Var SerPorts%[0], SerPorts$[0];


Err%:=SerialOpen(SerPorts%[], SerPorts$[]);
If err% > 0 then
            Resize SerPorts%[Err%];
            Resize SerPorts$[Err%];
Err%:=SerialOpen(SerPorts%[], SerPorts$[]);

  


    DlgCreate("Serial port select");  'Start new dialog
    DlgText("Serial port - Temperature sensor", 0, 1);
    DlgList(1, 25, SerPorts$[], 255, 35, 1);
    DlgButton(0,"Cancel");
    DlgButton(1,"OK");
    ok% := DlgShow(list0%);    'ok% is 0 if user cancels,  variables updated if not 
    
 endif   
    If Ok% < 0 or Len(SerPorts%[]) = 0 then    'If cancelled or no serial ports detected...
    Message("No serial port defined. Continuing with no temperature sensor");
'    Port% := -1;
        Return -1;
    endif
    
return SerPorts%[list0%]
end

Func GetTempData%();
'Printlog("\nGetTempData%");
If samplestatus() = 2 then
    
    
    View(Samplehandle(0));
    Var t := Maxtime();
    If t > LTime then
        Var ct% := Count(TMark%, Ltime, t);
        If Ct% > 0 then
            Var Time, i%, Code%[4], In$, Temp%[1];    'Temp is integer for discrete levels
            Time := LTime;
            
            Var arr[ct%];
            
            For i% := 1 to ct% do
                time := Nexttime(TMark%, time, code%[], in$);
                
                if code%[0] = 0 then
                    
                    If Left$(in$, 1) = "1" then
                        Temp%[0] := Val(Right$(In$, 7));
                        ChanWriteEvent(TempChan%, Time, Code%[], Temp%[0]);             
                    endif
                    
                endif                    
                Yield();
            next                
            Yield();
            Ltime := t; 
        endif 
        
    endif    
endif
                Yield();
            
Return 1
end

Func GetBaseMean%();
Var Mean := ChanMeasure(DopFluxCh2%, 2, 0, Baselinelen%);
Var SD := ChanMeasure(DopFluxCh2%, 12, 0, Baselinelen%);
VirtualChan(SigChange%, Print$("Ch(%d)<%f-%f", DopFluxCh2%, Mean, SD), 0, 0.01, 0);  'Edit virtual channel
Return 1
end

Func FileSaving%(Opt%, State%);
SampleStop();
NumberDigMarks%(DigMk%);
    FileSaveAs(Fname$, -1);
    Data% := -1;
    ToolbarSet(5, "Start trial", Sample%);   'Link to function
'FileSaveAs(WindowTitle$(), -1);
State% := -1;
    Tidy%(State%);


Return 1
end

Func NumberDigMarks%(DigMk%);
View(data%);
Var Ct% := Count(DigMk%, 0, Maxtime());
If Ct% <= 0 then return 1 endif

Var DigTemp% := Memchan(8, 32);
DrawMode(DigTemp%, 14, 3, 0, 0); 'Set Text
MarkShow(DigTemp%, 0, 0); 'Set marker to display and mode
Chanshow(DigTemp%);

Var DigTimes[ct%], Code%[4];
Var EndT := Maxtime();
Arrconst(Code%[], 0);
Chandata(DigMk%, DigTimes[], 0, EndT);


Var i% := 0;
For i% := 0 to ct%-1 do
        Memsetitem(DigTemp%, 0, DigTimes[i%], Code%[], Print$("%d Amp = %,2f", i%+1, Out[i%]));
next 

Var list%[32];
Chanlist(List%[], 128);
if List%[0] > 0 then
    MemSave(DigTemp%, List%[1], 0);
    DrawMode(List%[1], 14, 3, 0, 0); 'Set Text
    MarkShow(List%[1], 0, 0); 'Set marker to display and mode
    Chanshow(List%[1]);
endif    
Return 1
end

Func TidyData%();

If SampleStatus() = -1 then
'If ViewKind(DataDup%) = 0 then
'    View(DataDup%);
'    FileClose(0, -1);
'endif

If ViewKind(Data%) = 0 then
    View(Data%);
    Fileclose(1, 0);
    endif
 View(app(1)).WindowVisible(1);   
endif

Return 1
end

Func Quit%();
RestoreApps();

if View(App(1)).WindowVisible() = 0 then 'Main toolbar
    View(App(1)).WindowVisible(1);
endif 

if View(App(6)).WindowVisible() = 0 then 'Script bar
    View(App(6)).WindowVisible(1);
endif 

Halt;

Return 0;
end

